<section class="mb-5 p-6 border border-indigo-100 dark:border-indigo-900/50 rounded-2xl bg-gradient-to-b from-white to-indigo-50/40 dark:from-slate-800 dark:to-indigo-950/30 shadow-lg">
  <h1 class="text-3xl font-bold text-slate-900 dark:text-slate-50 mb-3">Welcome to Project Starter</h1>
  <p class="text-slate-500 dark:text-slate-400">
    You are signed in and ready to build. This placeholder page is where your
    project's main content will go.
  </p>
  <% if (session.authenticatedUser) { %>
    <p class="text-slate-500 dark:text-slate-400 mt-2 mb-0">
      Signed in as <strong class="text-slate-700 dark:text-slate-200"><%= session.authenticatedUser.displayName %></strong>
      (<%= session.authenticatedUser.email %>, role:
      <strong class="text-slate-700 dark:text-slate-200"><%= session.authenticatedUser.role %></strong>).
    </p>
  <% } %>
</section>

<% if (pageError) { %>
  <%- include("partials/error", { message: pageError }) %>
<% } %>

<section class="max-w-3xl p-6 border border-slate-200 dark:border-slate-700 rounded-2xl bg-white dark:bg-slate-800 shadow-lg">
  <div class="mb-4">
    <h2 class="text-xl font-semibold mb-2 text-slate-900 dark:text-slate-50">Getting Started</h2>
    <p class="text-slate-500 dark:text-slate-400">
      This starter application provides authentication and role-based authorization
      out of the box. Here are some ideas for where to begin:
    </p>
  </div>

  <ul class="list-disc pl-5 space-y-2 text-slate-700 dark:text-slate-300">
    <li>Replace this page with your project's main dashboard or landing page.</li>
    <li>Add new routes in <code class="bg-slate-100 dark:bg-slate-700 dark:text-slate-200 px-1 rounded text-sm">src/app.ts</code> and protect them with
      <code class="bg-slate-100 dark:bg-slate-700 dark:text-slate-200 px-1 rounded text-sm">requireAuthenticated</code> or <code class="bg-slate-100 dark:bg-slate-700 dark:text-slate-200 px-1 rounded text-sm">requireRole</code>.</li>
    <li>Create new EJS views in <code class="bg-slate-100 dark:bg-slate-700 dark:text-slate-200 px-1 rounded text-sm">src/views/</code>.</li>
    <li>Add your own models, services, and controllers under <code class="bg-slate-100 dark:bg-slate-700 dark:text-slate-200 px-1 rounded text-sm">src/</code>.</li>
    <li>Use the Prisma schema in <code class="bg-slate-100 dark:bg-slate-700 dark:text-slate-200 px-1 rounded text-sm">prisma/schema.prisma</code> to define your database tables.</li>
  </ul>
</section>

<section class="max-w-3xl mt-5 p-6 border border-slate-200 dark:border-slate-700 rounded-2xl bg-white dark:bg-slate-800 shadow-lg" x-data="{ open: false }">
  <button
    @click="open = !open"
    class="w-full flex items-center justify-between text-left bg-transparent border-0 p-0 cursor-pointer"
  >
    <h2 class="text-xl font-semibold text-slate-900 dark:text-slate-50">Alpine.js Demo</h2>
    <span class="text-slate-400 dark:text-slate-500 text-sm" x-text="open ? 'Hide' : 'Show'">Show</span>
  </button>

  <div x-show="open" x-transition class="mt-4">
    <p class="text-slate-500 dark:text-slate-400 mb-3">
      Alpine.js is included via CDN and ready to use. This collapsible section is
      a quick demonstration. Use <code class="bg-slate-100 dark:bg-slate-700 dark:text-slate-200 px-1 rounded text-sm">x-data</code>,
      <code class="bg-slate-100 dark:bg-slate-700 dark:text-slate-200 px-1 rounded text-sm">x-show</code>,
      <code class="bg-slate-100 dark:bg-slate-700 dark:text-slate-200 px-1 rounded text-sm">@click</code>, and other
      Alpine directives directly in your EJS templates.
    </p>
    <div x-data="{ count: 0 }" class="flex items-center gap-3">
      <button
        @click="count++"
        class="px-4 py-2 rounded-lg bg-indigo-600 dark:bg-indigo-500 text-white font-medium cursor-pointer hover:bg-indigo-700 dark:hover:bg-indigo-600 text-sm transition-colors"
      >
        Clicked: <span x-text="count">0</span>
      </button>
      <span class="text-sm text-slate-500 dark:text-slate-400">A simple Alpine.js counter</span>
    </div>
  </div>
</section>

<section class="max-w-3xl mt-5 p-6 border border-slate-200 dark:border-slate-700 rounded-2xl bg-white dark:bg-slate-800 shadow-lg">
  <h2 class="text-xl font-semibold mb-3 text-slate-900 dark:text-slate-50">Search Events</h2>

  <input
    type="text"
    name="query"
    placeholder="Search by title, description, or location..."
    hx-get="/events/search"
    hx-trigger="keyup changed search delay:400ms"
    hx-target="#event-results"
    hx-swap="innerHTML"
    class="w-full border border-slate-300 dark:border-slate-600 rounded-lg px-4 py-2 bg-white dark:bg-slate-900 text-slate-900 dark:text-slate-100 placeholder:text-slate-400 dark:placeholder:text-slate-500 focus:outline-none focus:border-indigo-400 dark:focus:border-indigo-500 transition-colors"
  />

  <div id="event-results" class="mt-4">
    <%- include("partials/event-search-results", { events: [] }) %>
  </div>
</section>
