<!doctype html>
<html lang="en" class="<%= darkMode ? 'dark' : '' %>">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Project Starter</title>
    <script>
      if (document.cookie.includes('darkMode=true')) {
        document.documentElement.classList.add('dark');
      }
    </script>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = { darkMode: 'class' }
    </script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3/dist/cdn.min.js"></script>
    <script src="https://unpkg.com/htmx.org@2.0.4"></script>
  </head>
  <body 
    x-data="{ dark: <%= darkMode %> }"
    x-init="$watch('dark', v => {
      document.documentElement.classList.toggle('dark', v);
      document.cookie = 'darkMode=' + v + ';path=/;max-age=31536000';
    })"
    class="min-h-screen bg-gradient-to-br from-slate-50 via-blue-50/30 to-indigo-50/20 dark:from-slate-950 dark:via-slate-900 dark:to-indigo-950/30 text-slate-900 dark:text-slate-100 p-6 transition-colors duration-200">
    <div class="max-w-5xl mx-auto">
      <nav class="flex items-center justify-between gap-3 mb-6 flex-wrap">

        <%# Dark mode toggle %>
        <button @click="dark = !dark"
          class="flex items-center gap-1.5 px-3 py-1.5 rounded-full border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-600 dark:text-slate-300 text-xs font-medium transition-all hover:border-indigo-300 dark:hover:border-indigo-600 hover:text-indigo-600 dark:hover:text-indigo-400 shadow-sm">
          <span x-text="dark ? '☀️' : '🌙'"></span>
          <span x-text="dark ? 'Light' : 'Dark'"></span>
        </button>

        <%# Logo %>
        <a
          href="<%= session?.authenticatedUser ? '/home' : '/login' %>"
          class="inline-flex items-center gap-2.5 px-4 py-3 rounded-xl bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 shadow-lg font-bold text-slate-900 dark:text-slate-100 no-underline hover:border-indigo-300 dark:hover:border-indigo-600 transition-colors"
        >
          <span class="w-2.5 h-2.5 rounded-full bg-gradient-to-b from-indigo-400 to-indigo-600"></span>
          Project Starter
        </a>

        <%# Nav links %>
        <div class="flex items-center gap-3 flex-wrap">
          <% if (session?.authenticatedUser) { %>

            <% if (session.authenticatedUser.role !== "admin") { %>
              <a href="/my-rsvps" class="text-indigo-600 dark:text-indigo-400 font-semibold no-underline hover:underline">
                My RSVPs
              </a>
            <% } %>

            <% if (session.authenticatedUser.role === "admin") { %>
              <a href="/admin/users" class="text-indigo-600 dark:text-indigo-400 font-semibold no-underline hover:underline">
                Manage Users
              </a>
            <% } %>

            <span class="text-slate-500 dark:text-slate-400">
              Signed in as <strong class="text-slate-700 dark:text-slate-200"><%= session.authenticatedUser.displayName %></strong>
              (<%= session.authenticatedUser.role %>)
            </span>

            <form method="post" action="/logout" class="m-0">
              <button
                type="submit"
                class="px-3.5 py-2 rounded-lg bg-white dark:bg-slate-800 text-indigo-600 dark:text-indigo-400 border border-slate-200 dark:border-slate-700 cursor-pointer hover:bg-indigo-50 dark:hover:bg-indigo-950/40 text-sm font-medium transition-colors"
              >
                Log out
              </button>
            </form>

          <% } else { %>
            <a href="/login" class="text-indigo-600 dark:text-indigo-400 font-semibold no-underline hover:underline">Log in</a>
          <% } %>
        </div>
      </nav>
      <main class="max-w-5xl mx-auto"><%- body %></main>
    </div>
  </body>
</html>
