<!doctype html>
<html lang="en" class="<%= darkMode ? 'dark' : '' %>">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Project Starter</title>
    <script>
      if (document.cookie.includes('darkMode=true')) {
        document.documentElement.classList.add('dark');
      }
    </script>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = { darkMode: 'class' }
    </script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3/dist/cdn.min.js"></script>
    <script src="https://unpkg.com/htmx.org@2.0.4"></script>
  </head>
  <body
    x-data="{ dark: <%= darkMode %> }"
    x-init="$watch('dark', v => {
      document.documentElement.classList.toggle('dark', v);
      document.cookie = 'darkMode=' + v + ';path=/;max-age=31536000';
    })"
    class="min-h-screen bg-gradient-to-br from-slate-50 via-blue-50/30 to-indigo-50/20 dark:from-slate-950 dark:via-slate-900 dark:to-indigo-950/30 text-slate-900 dark:text-slate-100 transition-colors duration-200">

    <%# ── Top bar ── %>
    <header class="sticky top-0 z-50 bg-white/80 dark:bg-slate-900/80 backdrop-blur border-b border-slate-200 dark:border-slate-700/60 px-6 py-3">
      <div class="max-w-5xl mx-auto flex items-center justify-between gap-4">

        <%# Logo %>
        <a href="<%= session?.authenticatedUser ? '/home' : '/login' %>"
          class="inline-flex items-center gap-2 font-bold text-slate-900 dark:text-slate-100 no-underline hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors shrink-0">
          <span class="w-2.5 h-2.5 rounded-full bg-gradient-to-b from-indigo-400 to-indigo-600"></span>
          Project Starter
        </a>

        <%# ── Page nav (authenticated only) ── %>
        <% if (session?.authenticatedUser) { %>
        <nav class="flex items-center gap-1 flex-wrap">
          <%
            const currentPath = typeof locals.currentPath !== 'undefined' ? locals.currentPath : '';
            function navLink(href, label) {
              const active = currentPath === href || (href !== '/home' && currentPath.startsWith(href));
              return '<a href="' + href + '" class="px-3 py-1.5 rounded-lg text-sm font-medium no-underline transition-colors ' + (
                active
                  ? 'bg-indigo-50 dark:bg-indigo-950/50 text-indigo-700 dark:text-indigo-300 border border-indigo-200 dark:border-indigo-800'
                  : 'text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 hover:text-slate-900 dark:hover:text-slate-100'
              ) + '">' + label + '</a>';
            }
          %>
          <%- navLink('/home', 'Home') %>
          <%- navLink('/events', 'Events') %>
          <%- navLink('/events/archive', 'Archive') %>
          <% if (session.authenticatedUser.role !== 'admin') { %>
            <%- navLink('/my-rsvps', 'My RSVPs') %>
          <% } %>
          <% if (session.authenticatedUser.role === 'admin' || session.authenticatedUser.role === 'staff') { %>
            <%- navLink('/events/new', 'New Event') %>
          <% } %>
          <% if (session.authenticatedUser.role === 'admin') { %>
            <%- navLink('/admin/users', 'Users') %>
          <% } %>
        </nav>
        <% } %>

        <%# ── Right side: user + dark toggle + logout ── %>
        <div class="flex items-center gap-2 shrink-0 flex-wrap justify-end">

          <% if (session?.authenticatedUser) { %>
            <span class="text-xs text-slate-500 dark:text-slate-400 hidden sm:inline">
              <strong class="text-slate-700 dark:text-slate-200"><%= session.authenticatedUser.displayName %></strong>
              · <%= session.authenticatedUser.role %>
            </span>
            <form method="post" action="/logout" class="m-0">
              <button type="submit"
                class="px-3 py-1.5 rounded-lg bg-white dark:bg-slate-800 text-slate-600 dark:text-slate-300 border border-slate-200 dark:border-slate-700 cursor-pointer hover:bg-red-50 dark:hover:bg-red-950/30 hover:text-red-600 dark:hover:text-red-400 hover:border-red-200 dark:hover:border-red-800 text-xs font-medium transition-colors">
                Log out
              </button>
            </form>
          <% } else { %>
            <a href="/login" class="text-sm text-indigo-600 dark:text-indigo-400 font-semibold no-underline hover:underline">Log in</a>
          <% } %>

          <%# Dark mode toggle %>
          <button @click="dark = !dark"
            class="flex items-center gap-1.5 px-3 py-1.5 rounded-full border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-600 dark:text-slate-300 text-xs font-medium transition-all hover:border-indigo-300 dark:hover:border-indigo-600 hover:text-indigo-600 dark:hover:text-indigo-400 shadow-sm">
            <span x-text="dark ? '☀️' : '🌙'"></span>
            <span x-text="dark ? 'Light' : 'Dark'"></span>
          </button>

        </div>
      </div>
    </header>

    <div class="max-w-5xl mx-auto px-6 py-6">
      <main><%- body %></main>
    </div>
  </body>
</html>
