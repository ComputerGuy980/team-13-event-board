<section class="mb-5 p-6 border border-indigo-100 dark:border-indigo-900/50 rounded-2xl bg-gradient-to-b from-white to-indigo-50/40 dark:from-slate-800 dark:to-indigo-950/30 shadow-lg">
  <h1 class="text-3xl font-bold text-slate-900 dark:text-slate-50 mb-3">Sign In</h1>
  <p class="text-slate-500 dark:text-slate-400">
    Log in with one of the demo accounts below to access the application.
  </p>
</section>

<% if (pageError) { %>
  <%- include("partials/error", { message: pageError }) %>
<% } %>

<section class="max-w-3xl p-6 border border-slate-200 dark:border-slate-700 rounded-2xl bg-white dark:bg-slate-800 shadow-lg">
  <div class="mb-4">
    <h2 class="text-xl font-semibold mb-2 text-slate-900 dark:text-slate-50">Log In</h2>
    <p class="text-slate-500 dark:text-slate-400">
      This starter uses three in-memory demo users with hashed passwords so you
      can focus on building your project features.
    </p>
  </div>

  <form class="grid gap-2.5" method="post" action="/login">
    <label for="email" class="text-sm font-medium text-slate-700 dark:text-slate-300">Email</label>
    <input
      id="email"
      name="email"
      type="email"
      autocomplete="username"
      required
      class="w-full px-3 py-2.5 border border-slate-300 dark:border-slate-600 rounded-xl bg-white dark:bg-slate-900 text-slate-900 dark:text-slate-100 placeholder:text-slate-400 focus:outline-none focus:border-indigo-400 dark:focus:border-indigo-500 transition-colors"
    />

    <label for="password" class="text-sm font-medium text-slate-700 dark:text-slate-300">Password</label>
    <input
      id="password"
      name="password"
      type="password"
      autocomplete="current-password"
      required
      class="w-full px-3 py-2.5 border border-slate-300 dark:border-slate-600 rounded-xl bg-white dark:bg-slate-900 text-slate-900 dark:text-slate-100 focus:outline-none focus:border-indigo-400 dark:focus:border-indigo-500 transition-colors"
    />

    <button
      type="submit"
      class="mt-1 px-4 py-2.5 rounded-lg bg-indigo-600 dark:bg-indigo-500 text-white font-medium cursor-pointer hover:bg-indigo-700 dark:hover:bg-indigo-600 transition-colors"
    >
      Log in
    </button>
  </form>

  <div class="mt-5 pt-5 border-t border-slate-200 dark:border-slate-700">
    <h3 class="text-base font-semibold mb-2 text-slate-900 dark:text-slate-50">Demo Users</h3>
    <ul class="list-disc pl-5 space-y-1 text-sm text-slate-700 dark:text-slate-300">
      <li><code class="bg-slate-100 dark:bg-slate-700 dark:text-slate-200 px-1 rounded">admin@app.test</code> / <code class="bg-slate-100 dark:bg-slate-700 dark:text-slate-200 px-1 rounded">password123</code> / <code class="bg-slate-100 dark:bg-slate-700 dark:text-slate-200 px-1 rounded">Admin</code></li>
      <li><code class="bg-slate-100 dark:bg-slate-700 dark:text-slate-200 px-1 rounded">staff@app.test</code> / <code class="bg-slate-100 dark:bg-slate-700 dark:text-slate-200 px-1 rounded">password123</code> / <code class="bg-slate-100 dark:bg-slate-700 dark:text-slate-200 px-1 rounded">Staff</code></li>
      <li><code class="bg-slate-100 dark:bg-slate-700 dark:text-slate-200 px-1 rounded">user@app.test</code> / <code class="bg-slate-100 dark:bg-slate-700 dark:text-slate-200 px-1 rounded">password123</code> / <code class="bg-slate-100 dark:bg-slate-700 dark:text-slate-200 px-1 rounded">User</code></li>
    </ul>
  </div>
</section>
