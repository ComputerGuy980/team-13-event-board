<%
  const allCategories = [...new Set(events.map(e => e.category))].sort();
  const activeCategory = typeof query !== 'undefined' ? query : 'all';
%>

<div class="max-w-2xl mx-auto py-6">

  <%# Header %>
  <div class="mb-6">
    <a href="/events" class="inline-flex items-center gap-1.5 text-sm text-slate-500 hover:text-slate-700 no-underline mb-4">
      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 14 14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M9 11L5 7l4-4"/>
      </svg>
      All events
    </a>
    <h1 class="text-2xl font-semibold text-slate-900">Archive</h1>
    <p class="text-sm text-slate-500 mt-1"><%= events.length %> past event<%= events.length === 1 ? '' : 's' %></p>
  </div>

  <%# Category filter pills — each triggers an HTMX GET that swaps only the list %>
  <% if (allCategories.length > 0) { %>
  <div class="flex items-center gap-2 flex-wrap mb-6">
    <a
      href="/events/archive"
      hx-get="/events/archive/filter"
      hx-target="#archive-list"
      hx-swap="innerHTML"
      hx-push-url="false"
      class="px-3 py-1.5 rounded-full text-xs font-medium border transition-colors no-underline cursor-pointer <%= activeCategory === 'all' ? 'bg-slate-800 text-white border-slate-800' : 'bg-white text-slate-600 border-slate-200 hover:border-slate-300 hover:bg-slate-50' %>"
    >
      All
    </a>
    <% allCategories.forEach(category => { %>
    <a
      href="/events/archive?category=<%= encodeURIComponent(category) %>"
      hx-get="/events/archive/filter?category=<%= encodeURIComponent(category) %>"
      hx-target="#archive-list"
      hx-swap="innerHTML"
      hx-push-url="false"
      class="px-3 py-1.5 rounded-full text-xs font-medium border transition-colors no-underline cursor-pointer <%= activeCategory === category ? 'bg-slate-800 text-white border-slate-800' : 'bg-white text-slate-600 border-slate-200 hover:border-slate-300 hover:bg-slate-50' %>"
    >
      <%= category %>
    </a>
    <% }) %>
  </div>
  <% } %>

  <%# Archive list — this div is the HTMX swap target %>
  <div id="archive-list">
    <%- include('_archive_list', { events, pageError }) %>
  </div>

</div>
