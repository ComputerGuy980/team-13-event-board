generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url = "file:./dev.db"
}
model Event {
  id            Int      @id @default(autoincrement())
  title         String
  description   String
  location      String
  category      String
  status        String   @default("draft")
  capacity      Int
  startDatetime Int
  endDatetime   Int
  organizerId   String
  createdAt     Int
  updatedAt     Int
}