generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url = "file:./dev.db"
}

model RSVP {
  id        String   @id @default(cuid())
  eventId   Int
  userId    String
  status    String   @default("going")
  createdAt DateTime @default(now())

  @@unique([eventId, userId])
  @@index([userId])
  @@index([eventId])
}

model Event {
  id            Int      @id @default(autoincrement())
  title         String
  description   String
  location      String
  category      String
  status        String   @default("draft")
  capacity      Int
  startDatetime Int
  endDatetime   Int
  organizerId   String
  createdAt     Int
  updatedAt     Int
}
