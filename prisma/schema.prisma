generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model RSVP {
  id        String   @id @default(cuid())
  eventId   Int
  userId    String
  status    String   @default("going")
  createdAt DateTime @default(now())

  @@unique([eventId, userId])
  @@index([userId])
  @@index([eventId])
}
